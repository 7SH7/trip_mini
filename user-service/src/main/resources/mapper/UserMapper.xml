<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.study.user.infrastructure.mybatis.UserMapper">

    <select id="countUsersByProvider" resultType="map">
        SELECT provider, COUNT(*) as count
        FROM users
        GROUP BY provider
    </select>

    <select id="findRecentUsers" resultType="com.study.user.domain.entity.User">
        SELECT *
        FROM users
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

</mapper>
